/* GTK3 & Standard Color Overrides */

@define-color theme_bg_color #242424;
@define-color theme_fg_color #dedede;
@define-color theme_base_color #242424;
@define-color theme_text_color #dedede;

@define-color theme_selected_bg_color #7157aa;
@define-color theme_selected_fg_color #242424;

@define-color theme_unfocused_bg_color #242424;
@define-color theme_unfocused_fg_color #dedede;
@define-color theme_unfocused_base_color #242424;
@define-color theme_unfocused_text_color #dedede;
@define-color theme_unfocused_selected_bg_color #7157aa;
@define-color theme_unfocused_selected_fg_color #242424;

@define-color insensitive_bg_color #212121;
@define-color insensitive_fg_color #949494;
@define-color insensitive_base_color #242424;
@define-color insensitive_base_fg_color #949494;
@define-color insensitive_selected_bg_color #212121;
@define-color insensitive_selected_fg_color #949494;

@define-color borders #212121;
@define-color unfocused_borders #212121;

@define-color warning_color #f67400;
@define-color error_color #da4453;
@define-color success_color #27ae60;
